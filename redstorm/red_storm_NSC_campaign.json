    "NSC1": {
      "title": "Red Dawn",
      "number": 1,
      "date": "1987년 5월 18일",
      "time": "07:00 (여명, Dawn)",
      "detection": { "NATO": "D", "WP": "C" },
      "weather": "맑음. 날씨 표 굴리지 않음.",
      "map": "전체 맵 사용",
      "front": "NATO 측은 6302 6309 5811 5315 5718 5721 5522 5430 5632 6235 6940 6935 7538 7737 이서(on/west).",
      "closed_airfields": "없음",
      "inherent_AAA_IR_SAM": "없음",

      "briefing": "바르샤바 조약군 공세 개시 다음날 새벽, 소규모 공격대가 Kassel 공군기지 활주로 파괴를 목표로 이동 중. NATO는 준비 부족 상태. F-15 2개 편대가 여명에 Allendorf 기지에서 긴급 출격.",

      "targets": "WP 공격대가 Kassel 공군기지(4514)에 도달하여 <br>폭격하는 것을 저지.",

      "NATO_OOB": {
        "공중": [
          { "국적": "US", "수량": "2 x {2}", "기종": "F-15A", "임무": "CAP", "공격성": "+0", "설정": "NATO 궤도점 인접, 미탐지, 남향, 초저고도", "조종사_등급": "정규군" }
        ],
        "궤도점": ["3422"]
      },

      "WP_OOB": {
        "공중_일반": {
          "설명": "WP 궤도점 1(6521) 인접 1헥스 내에 미탐지 일반 WP 비행대 A, B, C, D 배치. 북향, 중고도.",
          "플라이트플랜_A": ["A1-6519", "A2-6515", "A3-5108", "A4-4511", "A5-4514"],
          "활성화_시_기종_굴림": "1–4: Su-24C, 5–10: MiG-29A"
        },
        "실제_비행대": [
          { "국적": "USSR", "수량": "1 x {4}", "기종": "MiG-29A", "임무": "근접 호위(Close Escort)", "공격성": "+1", "조종사_등급": "정규군" },
          { "국적": "USSR", "수량": "2 x {2}", "기종": "Su-24C", "임무": "폭격(Bombing)", "공격성": "+1", "조종사_등급": "정규군" }
        ]
      },

      "SSR": [
        "봇 비행대는 PAC5의 모든 규칙을 따르되 아래 예외를 적용.",
        "봇 비행대 활성화 시 더미 최대 1개. 1–5는 실제 비행대, 6–10은 더미. 활성화 굴림에 페널티 미적용.",
        "일반 봇 비행대는 PAC5의 '≥8 교전 없음 → 비전투 행동' 규칙 무시. 대신 전투 스로틀로 Su-24C 클린 프로필을 사용해 플라이트 플랜 2헥스 이내에서 이동.",
        "탐지된 적 비행대가 동일 헥스 또는 7헥스 이내에 있으면 PAC5 교전 행동으로 전환.",
        "활성화 후 Su-24C 폭격 비행대라면 교전 행동 무시, 폭격 임무로 방어하며 플라이트 플랜 유지.",
        "활성화 후 MiG-29A라면 근접 호위 규칙 따름. 폭격 비행대가 없으면 가장 가까운 일반 비행대 호위. 탐지된 적이 7헥스 내라면 PAC5 교전 행동.",
        "봇 비행대 활성화 후 탐지된 적이 7헥스 내 없으면: 전투 스로틀, 중고도 이동(급상승 금지), 플라이트 플랜 최근 웨이포인트로 복귀 또는 무장 보유 폭격 비행대 호위 재개.",
        "웨이포인트 A4에서 미활성화 일반 비행대 및 Su-24C는 저고도로 강하하여 폭격 구간 동안 저고도 유지.",
        "일반 비행대가 목표 헥스(4514)에 도달하고 미활성화 Su-24C가 남아있으면 해당 비행대는 Su-24C로 활성화되어 폭격.",
        "봇 Su-24C가 Kassel(4514)에 도달하면 폭격 굴림 없이 자동으로 활주로 파괴 (이 시나리오 한정).",
        "다음 랜덤 이벤트 무시: 5(WP QRA), 6(SAM 아군 오사), 11(NATO QRA), 14(방향 탐지), 15(SEAD 공격)."
      ],

      "victory_conditions": {
        "type": "특수 (VP 없음)",
        "NATO_승리": "Su-24C가 Kassel(4514)에 도달하기 전에 폭격을 저지하면 NATO 승리.",
        "NATO_패배": "무장한 Su-24C 편대가 Kassel(4514)에 도달하면 즉시 NATO 패배로 시나리오 종료."
      }
    },

